# export env
export CC=icx
export CXX=icpx
export FC=ifx
export F77=ifx
export F90=ifx
export MPIFC=mpiifx
export MPIF77=mpiifx
export MPIF90=mpiifx
export MPICC=mpiicx
export MPICXX=mpiicpx
export CFLAGS="-fPIC -fPIE -O3 -Wno-implicit-function-declaration -Wno-incompatible-function-pointer-types -Wno-incompatible-function-pointer-types -Wno-unused-command-line-argument"
export FFLAGS=""
export FCFLAGS=""
export CXXFLAGS="-Wall -DHAVE_ISATTY"
export DIR=/home/psiriset/libraries

# Instal libraries
# Zlib 
wget -c https://github.com/madler/zlib/releases/download/v1.3.1/zlib-1.3.1.tar.gz
CC=mpiicx FC=mpiifx F77=mpiifx F90=mpiifx CXX=mpiicpx ./configure --prefix=/home/psiriset/libraries
make
make install
#libpng (1.6.39)
wget -c https://download.sourceforge.net/libpng/libpng-1.6.39.tar.gz
CC=mpiicx FC=mpiifx F77=mpiifx F90=mpiifx CXX=mpiicpx ./configure --prefix=/home/psiriset/libraries
make
make install
# JasPer (1.900.1)
wget -c https://www2.mmm.ucar.edu/wrf/OnLineTutorial/compile_tutorial/tar_files/jasper-1.900.1.tar.gz
export LDFLAGS=-L/home/psiriset/libraries/lib
export CPPFLAGS=-I/home/psiriset/libraries/include
CC=mpiicx FC=mpiifx F77=mpiifx F90=mpiifx CXX=mpiicpx CFLAGS="-O3 -fPIC -Wno-error=implicit-function-declaration -Wno-implicit-function-declaration -Wno-error=incompatible-function-pointer-types -Wno-incompatible-function-pointer-types" ./configure --prefix=/home/psiriset/libraries
make
make install
* jika error kemungkinan masalahnya disini (bisa update jasper ver 2)
# HDF5 (1.14.6)
wget -c https://github.com/HDFGroup/hdf5/releases/download/hdf5_$HDF5_Version/hdf5-1.14.6.tar.gz
export CFLAGS="-O3 -fPIC -Wno-unused-command-line-argument -Wno-implicit-function-declaration -Wno-incompatible-function-pointer-types"
export LDFLAGS="-L/home/psiriset/libraries/lib -Wl,-rpath,/home/psiriset/libraries/lib"
CC=mpiicx FC=mpiifx F77=mpiifx F90=mpiifx CXX=mpiicpx ./configure --prefix=/home/psiriset/libraries --with-zlib=/home/psiriset/libraries --enable-hl --enable-fortran --enable-parallel
make
make install
# Parallel-NetCDF (1.14.1)
wget -c https://parallel-netcdf.github.io/Release/pnetcdf-1.14.1.tar.gz
CC=mpiicx FC=mpiifx F77=mpiifx F90=mpiifx CXX=mpiicpx \
./configure --prefix=$DIR --enable-static
make
make install
# NetCDF-C (4.9.3)
wget -c https://github.com/Unidata/netcdf-c/archive/refs/tags/v4.9.3.tar.gz
export CPPFLAGS=-I$DIR/include
export LDFLAGS="-L$DIR/lib -Wl,-rpath,$DIR/grib2/lib"
export LIBS="-lhdf5_hl -lhdf5 -lz -lcurl -lgfortran -lgcc -lm -ldl -lpnetcdf"
CC=mpiicx FC=mpiifx F77=mpiifx F90=mpiifx CXX=mpiicpx \
./configure --prefix=/home/psiriset/libraries --disable-dap --enable-netcdf-4 --enable-netcdf4 --enable-pnetcdf --enable-cdf5 --enable-parallel-tests --enable-logging
make
make install
# NetCDF-Fortran (4.6.2)
wget -c https://github.com/Unidata/netcdf-fortran/archive/refs/tags/v4.6.2.tar.gz
export LD_LIBRARY_PATH=$DIR/lib:$LD_LIBRARY_PATH
export HDF5_PLUGIN_PATH=/home/psiriset/libraries/hdf5/lib/plugin
export CPPFLAGS="-I$DIR/include -I$DIR/include"
export LDFLAGS="-L$DIR/lib -L$DIR/lib -Wl,-rpath,$DIR/lib -Wl,-rpath,$DIR/lib"
export LIBS="-lnetcdf -lpnetcdf -lcurl -lhdf5_hl -lhdf5 -lz -lm -ldl -lgcc -lgfortran"
#ioapi
mkdir ioapi
wget ioapi.tar.gz
tar -zxvf ioapi.tar.gz
cd iaopi
export BIN=Linux2_x86_64ifort
export CPLMODE=nocpl
mkdir $BIN
cp Makefile.template Makefile
#edit Makefile (nanti dirapihin)
sed -i '193s|-lnetcdff -lnetcdf| -L/home/psiriset/libraries/lib -lnetcdff -lnetcdf -lhdf5hl_fortran -lhdf5_fortran -lhdf5_hl -lhdf5 -ljpeg -lm -lz -lcurl|g' /home/psiriset/raw/ioapi/Makefile
sed -i '210s|${IODIR}/Makefile ${TOOLDIR}/Makefile| |g' /home/psiriset/raw/ioapi/Makefile
# edit file 
vi ioapi/Makeinclude.Linux2_x86_64ifort
# ubah bagian
AR   = ar
CC   = icx
CXX  = icpx
FC   = ifx -auto -warn notruncated_source -Bstatic -static-intel
M4   = m4
LINK = $(CC)
# dan 
OMPFLAGS  = -qopenmp      # for Intel compilers, version 15 or earlier
OMPLIBS   = -qopenmp
# edit file sortic.c
vi /home/psiriset/raw/ioapi/ioapi/sortic.c
# tambah
#include  <stdlib.h>
make configure
make
make install
